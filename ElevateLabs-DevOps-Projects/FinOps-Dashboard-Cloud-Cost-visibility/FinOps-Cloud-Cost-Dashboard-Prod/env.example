# FinOps Dashboard — Environment Configuration
# Copy to .env and fill in values for production use.
# All AWS_* variables are optional — omit to use simulation mode.

# ── AWS Credentials ────────────────────────────────────────────────
# Required only for --mode aws. Needs: ce:GetCostAndUsage IAM permission.
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY_HERE
AWS_DEFAULT_REGION=us-east-1

# ── GCP (Optional) ────────────────────────────────────────────────
# GCP_PROJECT_ID=my-gcp-project
# GCP_BILLING_DATASET=billing_export

# ── Application ────────────────────────────────────────────────────
FINOPS_DB_PATH=./data/finops.db
LOG_LEVEL=INFO

# ── Grafana (if using Docker Compose) ─────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_in_production
