{
  "id": null,
  "uid": "observability-main",
  "title": "Complete Observability Dashboard",
  "description": "Unified view of metrics, logs, and traces for the sample application",
  "tags": ["observability", "metrics", "logs", "traces"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "🟢 Service Health Overview",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "App Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "up{job=\"sample-app\"}", "legendFormat": "App" }]
    },
    {
      "id": 3,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }
        }
      },
      "targets": [{ "expr": "sum(rate(http_requests_total[1m]))", "legendFormat": "Req/s" }]
    },
    {
      "id": 4,
      "title": "Error Rate (%)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] }
        }
      },
      "targets": [{ "expr": "100 * sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))", "legendFormat": "Error %" }]
    },
    {
      "id": 5,
      "title": "p95 Latency (ms)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 1000 }] }
        }
      },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le)) * 1000", "legendFormat": "p95" }]
    },
    {
      "id": 6,
      "title": "Active Requests",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 100 }] }
        }
      },
      "targets": [{ "expr": "http_active_requests", "legendFormat": "Active" }]
    },
    {
      "id": 7,
      "title": "Total Errors",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }
        }
      },
      "targets": [{ "expr": "sum(increase(app_errors_total[1h]))", "legendFormat": "Errors (1h)" }]
    },
    {
      "id": 10,
      "title": "📊 HTTP Traffic Metrics",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 11,
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(http_requests_total[2m]))",
          "legendFormat": "{{ endpoint }}"
        }
      ]
    },
    {
      "id": 12,
      "title": "Latency Percentiles",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p90" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 13,
      "title": "HTTP Status Code Distribution",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "pieType": "donut" },
      "targets": [
        { "expr": "sum by (status_code) (increase(http_requests_total[1h]))", "legendFormat": "HTTP {{ status_code }}" }
      ]
    },
    {
      "id": 14,
      "title": "Error Rate by Type",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      },
      "targets": [
        { "expr": "sum by (error_type) (rate(app_errors_total[5m]))", "legendFormat": "{{ error_type }}" }
      ]
    },
    {
      "id": 15,
      "title": "DB Query Latency by Operation",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{ operation }}"
        }
      ]
    },
    {
      "id": 20,
      "title": "📝 Application Logs",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "id": 21,
      "title": "Log Stream (All Levels)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 23 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        { "expr": "{service=\"sample-app\"}", "legendFormat": "" }
      ]
    },
    {
      "id": 22,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 10, "w": 8, "x": 16, "y": 23 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      },
      "targets": [
        { "expr": "sum by (level) (count_over_time({service=\"sample-app\"}[1m]))", "legendFormat": "{{ level }}" }
      ]
    },
    {
      "id": 30,
      "title": "🏗️ Infrastructure Metrics",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 }
    },
    {
      "id": 31,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU {{ instance }}"
        }
      ]
    },
    {
      "id": 32,
      "title": "Memory Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 34 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used Memory" },
        { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Available Memory" }
      ]
    },
    {
      "id": 33,
      "title": "Container CPU Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 34 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\".*sample-app.*\"}[5m]) * 100",
          "legendFormat": "{{ name }}"
        }
      ]
    },
    {
      "id": 40,
      "title": "💼 Business Metrics",
      "type": "row",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 }
    },
    {
      "id": 41,
      "title": "Orders by Status",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 43 },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "expr": "sum by (status) (business_orders_total)", "legendFormat": "{{ status }}" }
      ]
    },
    {
      "id": 42,
      "title": "Order Rate Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 43 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        { "expr": "sum by (status) (rate(business_orders_total[5m]))", "legendFormat": "Orders {{ status }}" }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus",
        "current": {}
      },
      {
        "name": "loki_datasource",
        "type": "datasource",
        "pluginId": "loki",
        "label": "Loki",
        "current": {}
      }
    ]
  }
}
