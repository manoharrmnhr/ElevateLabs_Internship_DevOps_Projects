        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "endpoint",
        "options": [],
        "query": {"query": "label_values(http_requests_total, endpoint)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Endpoint"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
