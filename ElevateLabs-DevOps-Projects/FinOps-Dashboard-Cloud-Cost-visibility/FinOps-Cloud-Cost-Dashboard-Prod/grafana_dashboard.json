{
  "__inputs": [
    {
      "name": "DS_FINOPS_SQLITE",
      "label": "FinOps SQLite",
      "description": "SQLite datasource pointing to data/finops.db",
      "type": "datasource",
      "pluginId": "frser-sqlite-datasource",
      "pluginName": "SQLite"
    }
  ],
  "__requires": [
    { "type": "grafana",    "id": "grafana",                "name": "Grafana",    "version": "10.0.0" },
    { "type": "datasource", "id": "frser-sqlite-datasource","name": "SQLite",     "version": "3.3.0"  },
    { "type": "panel",      "id": "gauge",                  "name": "Gauge",      "version": "" },
    { "type": "panel",      "id": "timeseries",             "name": "Time series","version": "" },
    { "type": "panel",      "id": "table",                  "name": "Table",      "version": "" },
    { "type": "panel",      "id": "stat",                   "name": "Stat",       "version": "" },
    { "type": "panel",      "id": "barchart",               "name": "Bar chart",  "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "FinOps Free Tier Usage Tracker — Real-time AWS cloud cost visibility dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "gridPos":{"h":2,"w":24,"x":0,"y":0}, "id":100,
      "type":"text", "title":"",
      "options":{"content":"## ☁️ FinOps Dashboard — AWS Free Tier Usage Tracker\n**Monitor cloud resource consumption in real-time. Services colored 🟢 SAFE | 🟡 AT-RISK | 🔴 BREACH based on projected month-end usage.**","mode":"markdown"},
      "transparent":true },

    { "gridPos":{"h":4,"w":4,"x":0,"y":2}, "id":1,
      "title":"Total Services", "type":"stat",
      "datasource":"${DS_FINOPS_SQLITE}",
      "options":{"colorMode":"background","graphMode":"none","reduceOptions":{"calcs":["last"]}},
      "fieldConfig":{"defaults":{"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"blue","value":null}]},"unit":"short"}},
      "targets":[{"rawQueryText":"SELECT total_services AS value FROM daily_summary ORDER BY summary_date DESC LIMIT 1","queryType":"table","timeColumns":[]}] },

    { "gridPos":{"h":4,"w":4,"x":4,"y":2}, "id":2,
      "title":"✅ Safe Services", "type":"stat",
      "datasource":"${DS_FINOPS_SQLITE}",
      "options":{"colorMode":"background","graphMode":"none"},
      "fieldConfig":{"defaults":{"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":null}]},"unit":"short"}},
      "targets":[{"rawQueryText":"SELECT safe_count AS value FROM daily_summary ORDER BY summary_date DESC LIMIT 1","queryType":"table","timeColumns":[]}] },

    { "gridPos":{"h":4,"w":4,"x":8,"y":2}, "id":3,
      "title":"⚠️ At-Risk Services", "type":"stat",
      "datasource":"${DS_FINOPS_SQLITE}",
      "options":{"colorMode":"background","graphMode":"none"},
      "fieldConfig":{"defaults":{"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":null},{"color":"orange","value":1}]},"unit":"short"}},
      "targets":[{"rawQueryText":"SELECT at_risk_count AS value FROM daily_summary ORDER BY summary_date DESC LIMIT 1","queryType":"table","timeColumns":[]}] },

    { "gridPos":{"h":4,"w":4,"x":12,"y":2}, "id":4,
      "title":"🔴 Breach Services", "type":"stat",
      "datasource":"${DS_FINOPS_SQLITE}",
      "options":{"colorMode":"background","graphMode":"none"},
      "fieldConfig":{"defaults":{"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":null},{"color":"red","value":1}]},"unit":"short"}},
      "targets":[{"rawQueryText":"SELECT breach_count AS value FROM daily_summary ORDER BY summary_date DESC LIMIT 1","queryType":"table","timeColumns":[]}] },

    { "gridPos":{"h":4,"w":8,"x":16,"y":2}, "id":5,
      "title":"💰 Estimated Monthly Overage (USD)", "type":"stat",
      "datasource":"${DS_FINOPS_SQLITE}",
      "options":{"colorMode":"background","graphMode":"area","reduceOptions":{"calcs":["last"]}},
      "fieldConfig":{"defaults":{"unit":"currencyUSD","decimals":4,"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":null},{"color":"orange","value":0.01},{"color":"red","value":1.0}]}}},
      "targets":[{"rawQueryText":"SELECT summary_date AS time, total_overage AS value FROM daily_summary ORDER BY summary_date","queryType":"timeseries","timeColumns":["time"]}] },

    { "gridPos":{"h":10,"w":16,"x":0,"y":6}, "id":10,
      "title":"📈 Daily Usage Trend — All Services (30 Days)",
      "type":"timeseries",
      "datasource":"${DS_FINOPS_SQLITE}",
      "options":{"legend":{"calcs":["mean","max","last"],"displayMode":"table","placement":"bottom"},"tooltip":{"mode":"multi"}},
      "fieldConfig":{"defaults":{"custom":{"lineWidth":2,"fillOpacity":8,"spanNulls":true}}},
      "targets":[{"rawQueryText":"SELECT date AS time, service_name AS metric, SUM(usage_amount) AS value FROM usage_data WHERE date >= date('now','-30 days') GROUP BY date, service_name ORDER BY date","queryType":"timeseries","timeColumns":["time"]}] },

    { "gridPos":{"h":10,"w":8,"x":16,"y":6}, "id":11,
      "title":"🎯 Free Tier Usage % (Projected Month-End)",
      "type":"gauge",
      "datasource":"${DS_FINOPS_SQLITE}",
      "options":{"reduceOptions":{"calcs":["last"]},"showThresholdLabels":true,"showThresholdMarkers":true,"minVizWidth":75,"minVizHeight":75},
      "fieldConfig":{"defaults":{"unit":"percent","min":0,"max":120,"decimals":1,"color":{"mode":"thresholds"},"thresholds":{"mode":"absolute","steps":[{"color":"green","value":null},{"color":"orange","value":70},{"color":"red","value":100}]}}},
      "targets":[{"rawQueryText":"SELECT service_name AS metric, usage_pct AS value FROM alerts WHERE evaluated_at = (SELECT MAX(evaluated_at) FROM alerts) ORDER BY usage_pct DESC","queryType":"table","timeColumns":[]}] },

    { "gridPos":{"h":9,"w":24,"x":0,"y":16}, "id":20,
      "title":"📋 Current Alert Status — All Services",
      "type":"table",
      "datasource":"${DS_FINOPS_SQLITE}",
      "options":{"footer":{"show":false},"sortBy":[{"displayName":"% Used","desc":true}]},
      "fieldConfig":{
        "defaults":{"custom":{"align":"auto"}},
        "overrides":[
          {"matcher":{"id":"byName","options":"risk_level"},
           "properties":[
             {"id":"custom.displayMode","value":"color-background"},
             {"id":"mappings","value":[
               {"type":"value","options":{"SAFE":{"color":"green","text":"✅ SAFE"},"AT-RISK":{"color":"orange","text":"⚠️ AT-RISK"},"BREACH":{"color":"red","text":"🔴 BREACH"}}}
             ]}
           ]
          },
          {"matcher":{"id":"byName","options":"usage_pct"},
           "properties":[{"id":"unit","value":"percent"},{"id":"custom.width","value":100}]}
        ]
      },
      "targets":[{"rawQueryText":"SELECT service_name AS 'Service', month_to_date AS 'MTD', projected_usage AS 'Projected', free_tier_limit AS 'Limit', usage_unit AS 'Unit', usage_pct AS 'usage_pct', risk_level, overage_cost AS 'Est Overage $' FROM alerts WHERE evaluated_at = (SELECT MAX(evaluated_at) FROM alerts) ORDER BY usage_pct DESC","queryType":"table","timeColumns":[]}] },

    { "gridPos":{"h":7,"w":12,"x":0,"y":25}, "id":30,
      "title":"📊 Risk Count Over Time (30 Days)",
      "type":"timeseries",
      "datasource":"${DS_FINOPS_SQLITE}",
      "options":{"legend":{"displayMode":"list","placement":"bottom"},"tooltip":{"mode":"multi"}},
      "fieldConfig":{"defaults":{"custom":{"lineWidth":2,"fillOpacity":15}},
        "overrides":[
          {"matcher":{"id":"byName","options":"SAFE"},"properties":[{"id":"color","value":{"fixedColor":"green","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"AT-RISK"},"properties":[{"id":"color","value":{"fixedColor":"orange","mode":"fixed"}}]},
          {"matcher":{"id":"byName","options":"BREACH"},"properties":[{"id":"color","value":{"fixedColor":"red","mode":"fixed"}}]}
        ]},
      "targets":[{"rawQueryText":"SELECT summary_date AS time, safe_count AS 'SAFE', at_risk_count AS 'AT-RISK', breach_count AS 'BREACH' FROM daily_summary ORDER BY summary_date","queryType":"timeseries","timeColumns":["time"]}] },

    { "gridPos":{"h":7,"w":12,"x":12,"y":25}, "id":31,
      "title":"💸 Daily Estimated Overage Cost Trend (USD)",
      "type":"timeseries",
      "datasource":"${DS_FINOPS_SQLITE}",
      "options":{"legend":{"displayMode":"list","placement":"bottom"}},
      "fieldConfig":{"defaults":{"unit":"currencyUSD","custom":{"lineWidth":2,"fillOpacity":20},"color":{"fixedColor":"red","mode":"fixed"}}},
      "targets":[{"rawQueryText":"SELECT summary_date AS time, total_overage AS 'Overage Cost' FROM daily_summary ORDER BY summary_date","queryType":"timeseries","timeColumns":["time"]}] },

    { "gridPos":{"h":6,"w":24,"x":0,"y":32}, "id":40,
      "title":"🕐 Recent Alert History (Last 50 Events)",
      "type":"table",
      "datasource":"${DS_FINOPS_SQLITE}",
      "options":{"footer":{"show":false}},
      "fieldConfig":{"defaults":{},
        "overrides":[{"matcher":{"id":"byName","options":"risk_level"},"properties":[{"id":"custom.displayMode","value":"color-background"},{"id":"mappings","value":[{"type":"value","options":{"SAFE":{"color":"green"},"AT-RISK":{"color":"orange"},"BREACH":{"color":"red"}}}]}]}]},
      "targets":[{"rawQueryText":"SELECT substr(evaluated_at,1,16) AS 'Evaluated At', service_name AS 'Service', risk_level, ROUND(usage_pct,1) || '%' AS '% Used', '$' || ROUND(overage_cost,4) AS 'Est Cost', substr(message,1,90) AS 'Message' FROM alerts ORDER BY evaluated_at DESC, usage_pct DESC LIMIT 50","queryType":"table","timeColumns":[]}] }

  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["finops","aws","cloud-cost","free-tier","sqlite"],
  "time": {"from": "now-30d", "to": "now"},
  "title": "FinOps Free Tier Tracker",
  "uid": "finops-freetier-v2",
  "version": 2
}
